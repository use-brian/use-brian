{
  "name": "@use-brian/brian-kb",
  "version": "0.1.0",
  "description": "Parser, wikilink resolver, and lint checks for Use Brian knowledge bases. Shared between the API sync worker and the public CLI.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "kb": "./bin/kb.js"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/use-brian/use-brian",
    "directory": "packages/brian-kb"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "typescript": "^5.7",
    "vitest": "^3"
  }
}
