# Use Brian environment
#
# Only GEMINI_API_KEY is required to get started.
# `pnpm dev` auto-generates JWT_SECRET and defaults to an embedded PGLite
# store under ~/.usebrian/, so you do not need to set anything else here.
# Copy this file to .env if you like, or just let the launcher prompt you
# for the key on first run.

# ── LLM credential (at least one required) ──────────────────────────────────
# The `gemini` provider can run on AI Studio (GEMINI_API_KEY) or Vertex AI
# (VERTEX_PROJECT_ID), and a deployment can run Qwen-only via DASHSCOPE_API_KEY
# below. Pick what your region can reach: Google blocks the AI Studio developer
# API in some regions (Hong Kong, mainland China), where Vertex (asia-east2) or
# DashScope work instead. See docs/architecture/engine/provider-abstraction.md.

# Option A — Google AI Studio. Free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Option B — Vertex AI (same Gemini models, reachable in blocked regions).
# On GCP (Cloud Run/GCE) no key is needed: credentials come from the metadata
# server (ADC); grant the runtime service account roles/aiplatform.user.
# VERTEX_PROJECT_ID=my-gcp-project
# VERTEX_LOCATION=asia-east2          # host + regional quota pool (default asia-east2)
# VERTEX_SERVICE_ACCOUNT_JSON=        # only off-GCP: full service-account key JSON
# NOTE: long-recording transcription's `gemini` route uses the AI Studio Files
# API (no Vertex equivalent) — set GEMINI_API_KEY too, or RECORDING_TRANSCRIBER_*
# to scribe/qwen, if you use long recordings on Vertex.

# Option C — Qwen-only (no Google credential): set DASHSCOPE_API_KEY below.
# Known gap: PDF/office distillation is unavailable on Qwen (image-only).

# ── Web search (optional - falls back to DuckDuckGo when unset) ──────────────
# Set any one of these to upgrade the web-search tool beyond the free
# DuckDuckGo default. The first configured provider wins.
TAVILY_API_KEY=          # Tavily search (AI-optimized results)
BRAVE_SEARCH_API_KEY=    # Brave Search API
SERPER_API_KEY=          # Serper (Google Search results)
JINA_API_KEY=            # Jina Reader for cleaner page fetches (works without a key at lower rate limits)

# ── X / Twitter reading (optional) ──────────────────────────────────────────
# urlReader reads x.com / twitter.com status permalinks through the official
# X API v2 tweet lookup when TWITTER_BEARER_TOKEN is set (app-only Bearer from
# a Basic-tier+ X developer app; the Free tier cannot read tweets), and falls
# back to xAI Grok otherwise. XAI_API_KEY also enables the xSearch tool, which
# queries X via Grok, and reads non-permalink X URLs (profiles, search).
TWITTER_BEARER_TOKEN=
XAI_API_KEY=

# ── Model fallback (optional) ───────────────────────────────────────────────
# An optional resilience fallback used if Gemini is unavailable.
# Set FALLBACK_PROVIDER_ENABLED=true and provide an Anthropic key.
FALLBACK_PROVIDER_ENABLED=
ANTHROPIC_API_KEY=

# OpenAI-compatible endpoint key (DashScope — Qwen / DeepSeek). Leave empty to
# run Gemini-only. Set it (with no GEMINI_API_KEY / VERTEX_PROJECT_ID) to run
# QWEN-ONLY: chat then defaults to a Qwen model automatically — the gemini
# provider is not registered, so its models are absent from routing and menus.
DASHSCOPE_API_KEY=
# DashScope host override. Unset = international (Singapore). Set to the Beijing
# endpoint for a mainland-China deployment. Applies to Qwen chat, embeddings,
# and media (distill/voice).
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# Model for the watched browser-use exploration (browserExplore). Optional —
# defaults per available key: Anthropic => Haiku, else Gemini => Flash.
BROWSER_USE_MODEL=

# ── Advanced / self-hosting overrides (optional) ────────────────────────────
# Point at an external Postgres connection string to use it instead of the
# embedded PGLite brain.
DATABASE_URL=
# Auto-generated and persisted to ~/.usebrian/config.json if left unset.
JWT_SECRET=
# Shared secret for the API <-> doc-sync internal routes (the auto-on-save brain
# ingest enqueue + AI doc writes). Auto-generated and persisted to
# ~/.usebrian/config.json like JWT_SECRET; only set this by hand if you run the
# api and doc-sync as separate processes WITHOUT the launcher (both need the
# same value).
DOC_SYNC_SECRET=
# AES-GCM key (base64 of 32 bytes) that encrypts connector OAuth refresh-tokens
# and PATs at rest in connector_instance.credentials, and BYO channel bot
# credentials (Telegram/Slack/Discord bot tokens) in
# channel_integrations.credentials. Auto-generated and persisted to
# ~/.usebrian/config.json by the launcher; only set this by hand if you run
# the api WITHOUT the launcher. Without it, connecting a connector or a
# channel returns 503. Generate with: openssl rand -base64 32
CHANNEL_CREDENTIAL_KEY=
# Override the default port the app listens on.
PORT=
# Default wall-clock (ms) for a workflow `assistant_call` step / scheduled job /
# A2A consult that sets no explicit `depth`. Absent → 90000 (90s). Clamped to
# [1000, 300000]; a non-numeric value falls back to the default. An explicit
# step `depth.timeoutMs` or a `deep` tier still wins per-field.
ASSISTANT_CALL_TIMEOUT_MS=

# ── Messaging channels (optional) ───────────────────────────────────────────
# Studio → Channels connects your own Telegram / Slack / Discord bots; the
# storage + webhooks are part of the open core (CHANNEL_CREDENTIAL_KEY above is
# the only hard requirement). Two practical notes for self-hosting:
#
#   * Inbound webhooks need a PUBLICLY REACHABLE https base URL. Telegram
#     connect registers `${API_URL}/webhook/telegram/<channelId>` with
#     Telegram, and Slack needs `${API_URL}/webhook/slack/<channelId>` in its
#     app's Event Subscriptions — so when running locally, put a tunnel
#     (e.g. `cloudflared tunnel --url http://localhost:4000`, ngrok, Tailscale
#     Funnel) in front of the api and set API_URL to the tunnel URL before
#     connecting. The launcher defaults API_URL to http://localhost:4000,
#     which Telegram/Slack cannot reach.
API_URL=
#
#   * Discord does not use webhooks — it needs a persistent Gateway WebSocket.
#     `pnpm dev` starts the open `apps/discord-connector` locally on port 8090
#     and generates/persists its shared secret automatically. Set both values
#     below only to use an externally deployed connector instead. The external
#     service needs the same secret as the API and must relay inbound events to
#     `${API_URL}/internal/discord/inbound`.
DISCORD_CONNECTOR_URL=
# Auto-generated under ~/.usebrian/ for local boot. Required on both the API
# and connector when deploying the connector separately.
DISCORD_CONNECTOR_SECRET=
# WhatsApp BYON also uses a persistent bridge. `pnpm dev` starts the open
# connector locally on port 8091, points it at the same database as the API,
# sets its local filesystem credential directory to ~/.usebrian/wa-creds, and
# generates/persists the shared secret. Set both values only to use an external
# connector; that service must use the same DATABASE_URL as the API for BYON
# credential persistence and call back to `${API_URL}`.
WA_CONNECTOR_URL=
WA_CONNECTOR_SECRET=

# ── Connectors (optional) ───────────────────────────────────────────────────
# Built-in connectors (Google Calendar/Gmail/Drive, Notion, Fathom, GitHub) are
# off until you bring your own OAuth app credentials. GitHub uses a Personal
# Access Token entered in the UI and needs nothing here. The OAuth providers
# resolve their app client id/secret from ~/.usebrian/connectors.config.json
# (override path: CONNECTORS_CONFIG_PATH), e.g.
#   { "google": { "clientId": "...", "clientSecret": "..." } }
# or from these env vars as a fallback. Unset → that connector stays unavailable.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
FATHOM_CLIENT_ID=
FATHOM_CLIENT_SECRET=
